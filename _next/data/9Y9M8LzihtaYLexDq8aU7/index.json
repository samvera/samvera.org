{"pageProps":{"blogPosts":[{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"gmxjheo1ix1o"}},"id":"6lmXyEjbxK9c3DS6Mlp2ls","type":"Entry","createdAt":"2026-03-25T05:00:04.256Z","updatedAt":"2026-03-25T19:09:36.904Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":161,"revision":14,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"blogPost"}},"locale":"en-US"},"fields":{"title":"Announcing Hyku 7.0","slug":"announcing-hyku-7-0-release","publishDate":"2026-03-23T00:00-07:00","content":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"The Hyku community is proud to announce the release of Hyku 7.0. This milestone represents the continued collaboration of developers, institutions, and service providers across the Samvera ecosystem.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Hyku is a multi-tenant repository platform built on Hyrax that enables institutions and consortia to manage digital collections at scale. With each release, the community continues to strengthen the platform's flexibility, administrative tooling, and operational stability.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Hyku 7.0 builds on that foundation with improvements that make it easier to adapt metadata models, manage repository configuration, and maintain production environments.","marks":[],"data":{}}]},{"nodeType":"heading-2","data":{},"content":[{"nodeType":"text","value":"What's New in Hyku 7","marks":[],"data":{}}]},{"nodeType":"heading-3","data":{},"content":[{"nodeType":"text","value":"Flexible Metadata","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Hyku 7 takes support for flexible metadata out of preview and improves and stabilizes the work found in Hyku 6.2. This support for flexible metadata is enabled through Hyrax's dynamic metadata framework. This capability allows repository administrators to configure metadata fields with greater flexibility and evolve metadata models without extensive code changes.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Flexible metadata can be enabled through the ","marks":[],"data":{}},{"nodeType":"text","value":"HYRAX_FLEXIBLE","marks":[{"type":"code"}],"data":{}},{"nodeType":"text","value":" environment variable and provides a foundation for repositories to adapt their metadata schemas over time.","marks":[],"data":{}}]},{"nodeType":"heading-3","data":{},"content":[{"nodeType":"text","value":"Ingest and Import Improvements","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Hyku 7 introduces dynamically generated importer templates for Bulkrax. CSV templates are generated from active M3 profiles, custom mappings, and work types, which cuts manual setup and simplifies ingest for administrators.","marks":[],"data":{}}]},{"nodeType":"heading-3","data":{},"content":[{"nodeType":"text","value":"Accessibility Improvements","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Hyku 7 includes updates aligned with WCAG 2.1, including stronger ARIA labeling, improved keyboard navigation for complex UI, and better default-theme color contrast so repository content is easier to use for more people.","marks":[],"data":{}}]},{"nodeType":"heading-3","data":{},"content":[{"nodeType":"text","value":"Ecosystem Upgrades","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Hyku 7 aligns the platform with updated components across the Samvera ecosystem, including Hyrax, the underlying Rails framework, and related integrations such as Bulkrax, WillowSword, and hyrax-doi.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"These updates help ensure compatibility with the latest community developments, availability of security patches, and maintain a healthy ecosystem of interoperable tools.","marks":[],"data":{}}]},{"nodeType":"heading-3","data":{},"content":[{"nodeType":"text","value":"Administrative Improvements","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Hyku 7 expands administrative configuration options for repository maintainers.","marks":[],"data":{}}]},{"nodeType":"unordered-list","data":{},"content":[{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Exclude specific metadata fields from search result displays","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Improve validation of metadata configurations","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Strengthen handling of configuration errors for work types","marks":[],"data":{}}]}]}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"These enhancements give repository administrators more control when managing complex metadata and repository configurations.","marks":[],"data":{}}]},{"nodeType":"heading-3","data":{},"content":[{"nodeType":"text","value":"Stability and Maintenance Improvements","marks":[],"data":{}}]},{"nodeType":"unordered-list","data":{},"content":[{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Improvements to derivative processing","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Enhancements to advanced search behavior","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fixes for A/V streaming, collection-level permissions, and background job processing","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"General bug fixes and reliability improvements","marks":[],"data":{}}]}]}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Together these improvements contribute to a more stable and maintainable platform for digital repositories.","marks":[],"data":{}}]},{"nodeType":"heading-2","data":{},"content":[{"nodeType":"text","value":"Why This Matters","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"For repository administrators:","marks":[{"type":"bold"}],"data":{}}]},{"nodeType":"unordered-list","data":{},"content":[{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"More flexibility when configuring metadata","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Improved tools for managing repository configuration","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Greater stability in day-to-day operations","marks":[],"data":{}}]}]}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"For institutions:","marks":[{"type":"bold"}],"data":{}}]},{"nodeType":"unordered-list","data":{},"content":[{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"A repository platform that can evolve alongside institutional metadata needs","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Continued investment in open-source infrastructure","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Improved compatibility across the Samvera ecosystem","marks":[],"data":{}}]}]}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"For consortia:","marks":[{"type":"bold"}],"data":{}}]},{"nodeType":"unordered-list","data":{},"content":[{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Better support for multi-tenant repository deployments","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Greater flexibility for different tenants' metadata models","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"A stronger foundation for collaborative repository platforms","marks":[],"data":{}}]}]}]},{"nodeType":"heading-2","data":{},"content":[{"nodeType":"text","value":"Community Contributions","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Hyku 7.0 reflects contributions from developers, maintainers, and institutions across the Hyku and Samvera communities. The release represents ongoing collaboration to advance open, community-driven digital repository infrastructure. ","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Special thanks to everyone who helped to build and test Hyku 7 and especially to the following community members for their leadership and coordination of this release:","marks":[],"data":{}}]},{"nodeType":"unordered-list","data":{},"content":[{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Rob Kaufman","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":", community-supported Technical Coordinator for Hyku and Hyrax","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Nic Don Stanton-Roark","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":", community-supported Product Owner for Hyku","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":" ","marks":[],"data":{}},{"nodeType":"hyperlink","data":{"uri":"https://www.notch8.com/"},"content":[{"nodeType":"text","value":"Team Violet","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" at Notch8","marks":[],"data":{}}]},{"nodeType":"text","value":" ","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"West Virginia University Libraries","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" Staff","marks":[],"data":{}}]}]}]},{"nodeType":"heading-2","data":{},"content":[{"nodeType":"text","value":"Release Notes","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Full release notes, upgrade guidance, and technical details are available in the ","marks":[],"data":{}},{"nodeType":"hyperlink","data":{"uri":"https://github.com/samvera/hyku/releases"},"content":[{"nodeType":"text","value":"Hyku GitHub repository","marks":[],"data":{}}]},{"nodeType":"text","value":".","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"What can Hyku 7.0 enable for your project? Interested in learning more about Hyku?","marks":[{"type":"bold"}],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Join us for the next ","marks":[],"data":{}},{"nodeType":"hyperlink","data":{"uri":"https://samvera.atlassian.net/wiki/spaces/samvera/pages/419533203/Samvera+Hyku+Interest+Group"},"content":[{"nodeType":"text","value":"Hyku Interest Group call","marks":[],"data":{}}]},{"nodeType":"text","value":"! All are welcome to attend. You can also ask questions in the Hyku channel on the ","marks":[],"data":{}},{"nodeType":"hyperlink","data":{"uri":"https://samvera.atlassian.net/wiki/spaces/samvera/pages/405211682/Get+in+touch"},"content":[{"nodeType":"text","value":"Samvera Slack workspace","marks":[],"data":{}}]},{"nodeType":"text","value":", and check out videos of Hyku in action on the ","marks":[],"data":{}},{"nodeType":"hyperlink","data":{"uri":"https://www.youtube.com/channel/UC_m1Ovaaasa2ksyGaqz5i0Q/featured"},"content":[{"nodeType":"text","value":"Hyku YouTube channel","marks":[],"data":{}}]},{"nodeType":"text","value":".","marks":[],"data":{}}]}]}}},{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"gmxjheo1ix1o"}},"id":"39B7XhiMn7VRZoPXt2wSb9","type":"Entry","createdAt":"2026-03-18T15:33:44.832Z","updatedAt":"2026-03-18T15:33:44.832Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":5,"revision":1,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"blogPost"}},"locale":"en-US"},"fields":{"title":"Call for Proposals: Samvera Virtual Connect 2026","slug":"cfp-virtual-connect-2026","publishDate":"2026-03-18T00:00-04:00","content":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Samvera Virtual Connect","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" will take place ","marks":[],"data":{}},{"nodeType":"text","value":"Tuesday, May 12 and Wednesday, May 13, 2026","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":", from:","marks":[],"data":{}}]},{"nodeType":"unordered-list","data":{},"content":[{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"8:00–11:00 AM PDT","marks":[{"type":"bold"}],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"11:00 AM–2:00 PM EDT","marks":[{"type":"bold"}],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"15:00–18:00 UTC","marks":[{"type":"bold"}],"data":{}}]}]}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Virtual Connect is a ","marks":[],"data":{}},{"nodeType":"text","value":"free, informal opportunity to share work, ideas, and experiences","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" with current and potential adopters of Samvera technologies. The event takes place entirely online via Zoom, and presentations will be recorded for asynchronous viewing so the broader community can learn from them.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"This year’s Virtual Connect will include two days of programming, with presentations grouped into thematic blocks based on topic, audience, and time.","marks":[],"data":{}}]},{"nodeType":"heading-3","data":{},"content":[{"nodeType":"text","value":"What the Community Wants to See","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Every year, feedback from participants highlights the same request: ","marks":[],"data":{}},{"nodeType":"text","value":"more real-world stories from repository practitioners.","marks":[{"type":"bold"}],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"The community especially values presentations that highlight:","marks":[],"data":{}}]},{"nodeType":"unordered-list","data":{},"content":[{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Local repositories and collections","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Practical challenges and lessons learned","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Innovative tools and integrations","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Experiments, pilots, and works in progress","marks":[],"data":{}}]}]}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"We strongly encourage ","marks":[],"data":{}},{"nodeType":"text","value":"repository managers, developers, metadata specialists, and project leads","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" to share their experiences. Whether you are showcasing a successful project, a work in progress, or something that didn’t go as planned but taught valuable lessons, ","marks":[],"data":{}},{"nodeType":"text","value":"your perspective helps the entire community grow.","marks":[{"type":"bold"}],"data":{}}]},{"nodeType":"heading-1","data":{},"content":[{"nodeType":"text","value":"Presentation Types","marks":[],"data":{}}]},{"nodeType":"heading-2","data":{},"content":[{"nodeType":"text","value":"Repository Showcase","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"One of the most popular parts of Virtual Connect is seeing ","marks":[],"data":{}},{"nodeType":"text","value":"repositories in action","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":".","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Whether you're running a full Samvera-based repository such as ","marks":[],"data":{}},{"nodeType":"text","value":"Hyku","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":", building with components like ","marks":[],"data":{}},{"nodeType":"text","value":"ServerlessIIIF","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":", or experimenting with new approaches, we want to see what you’re building.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Repository Showcases are ","marks":[],"data":{}},{"nodeType":"text","value":"5–7 minute “show and tell” presentations","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" highlighting a repository in ","marks":[],"data":{}},{"nodeType":"text","value":"production or development","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":".","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Examples of what you might share:","marks":[],"data":{}}]},{"nodeType":"unordered-list","data":{},"content":[{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"A unique or innovative repository implementation","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"A particularly interesting collection","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"New features or user experience improvements","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Integrations with other tools or services","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Lessons learned from building or managing a repository","marks":[],"data":{}}]}]}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Short, practical demonstrations are especially welcome.","marks":[],"data":{}}]},{"nodeType":"heading-2","data":{},"content":[{"nodeType":"text","value":"Presentations","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"You can propose ","marks":[],"data":{}},{"nodeType":"text","value":"5, 10, or 20 minute presentations","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":".","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"We welcome submissions from across the ","marks":[],"data":{}},{"nodeType":"text","value":"entire Samvera ecosystem","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":", including topics directly related to Samvera as well as broader work with open repository technologies.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Below are some themes to inspire proposals, but feel free to submit other ideas.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Accessibility and access","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"\nHow are you making collections more accessible, equitable, or inclusive? What accessibility challenges could benefit from community collaboration?","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"“New to Samvera” experiences","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"\nIf your institution recently adopted Samvera technologies, what has the journey looked like so far?","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Adaptation and reuse","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"\nHave you implemented or adapted something originally developed by another organization in the community?","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Challenges and lessons learned","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"\nWe learn just as much from difficulties as successes. Share experiences with pilot projects, performance tuning, migrations, or integrations that didn’t go exactly as planned.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Integration","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"\nHow are you connecting your digital repository with other institutional systems or services?","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Ways we work together","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"\nIdeas for improving collaboration, processes, staffing models, or workflows across teams.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"New ideas and pilot projects","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"\nHave a new concept or experiment you’d like feedback on? This is a great space to say:\n","marks":[],"data":{}},{"nodeType":"text","value":"“Hear me out—here’s something we should try and why.”","marks":[{"type":"italic"}],"data":{}}]},{"nodeType":"heading-2","data":{},"content":[{"nodeType":"text","value":"Breakout Sessions","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Breakout sessions are ","marks":[],"data":{}},{"nodeType":"text","value":"45-minute virtual roundtables","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":", scheduled ","marks":[],"data":{}},{"nodeType":"text","value":"before or after the main Virtual Connect programming","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":".","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"These sessions are designed for ","marks":[],"data":{}},{"nodeType":"text","value":"interactive discussion","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" rather than formal presentations. Topics can be ","marks":[],"data":{}},{"nodeType":"text","value":"very focused or broadly exploratory","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":", and they provide a valuable opportunity to connect with others across the Samvera Community.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"If you propose a breakout session, you will be responsible for:","marks":[],"data":{}}]},{"nodeType":"unordered-list","data":{},"content":[{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Facilitating the discussion","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Bringing a few guiding questions or prompts to get the conversation started","marks":[],"data":{}}]}]}]},{"nodeType":"heading-2","data":{},"content":[{"nodeType":"text","value":"","marks":[],"data":{}},{"nodeType":"hyperlink","data":{"uri":"https://forms.gle/FcTza5db2TMSNRv19"},"content":[{"nodeType":"text","value":"Submit Your Proposal","marks":[],"data":{}}]},{"nodeType":"text","value":"","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"We welcome proposals from ","marks":[],"data":{}},{"nodeType":"text","value":"across the Samvera community and beyond","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":", including people who may be ","marks":[],"data":{}},{"nodeType":"text","value":"new to Samvera or considering adoption","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":".","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"","marks":[],"data":{}},{"nodeType":"hyperlink","data":{"uri":"https://forms.gle/FcTza5db2TMSNRv19"},"content":[{"nodeType":"text","value":"Proposal deadline:","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" ","marks":[],"data":{}},{"nodeType":"text","value":"Friday, April 17, 2026","marks":[{"type":"bold"}],"data":{}}]},{"nodeType":"text","value":"","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"We look forward to seeing the many ways your repositories, tools, and experiences are helping advance open, community-driven digital repositories.","marks":[],"data":{}}]}]}}},{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"gmxjheo1ix1o"}},"id":"4FCnfYLE018uwLuAp9QGDB","type":"Entry","createdAt":"2026-01-21T20:20:21.779Z","updatedAt":"2026-01-21T20:20:21.779Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":41,"revision":1,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"blogPost"}},"locale":"en-US"},"fields":{"title":"Rob Kaufman is Hyrax and Hyku Technology Coordinator for 2026","slug":"technical-coordinator-2026","publishDate":"2026-01-21T00:00-05:00","content":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"We’re excited to welcome Rob Kaufman to the new role of Technical Coordinator for the Hyrax and Hyku platforms. This role provides essential technical leadership and coordination at a moment when many institutions are facing funding constraints, and reliance on Hyrax and Hyku infrastructure continues to grow.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Rob brings more than 22 years of development experience and a proven leadership track record. He is the former head of Notch8 and prior to this role served as the Hyku Technical Lead. His deep knowledge of Samvera’s ecosystem, combined with long-standing relationships across the community, uniquely positions him to help us strengthen technical continuity today while building sustainable processes for the future.","marks":[],"data":{}}]},{"nodeType":"heading-4","data":{},"content":[{"nodeType":"text","value":"What Technical Coordination Will Do for Hyku and Hyrax","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Hyrax and Hyku are critical infrastructure for many institutions. They support repositories, preservation, access, and discovery services that our organizations depend on every day. At the same time, institutional funding cuts have reduced the capacity of individual teams to carry coordination, maintenance, and strategic alignment on their own.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"The Technical Coordinator role is contracted for 20 hours per month and designed to multiply community capacity by providing high-impact coordination, shared visibility, and continuity across projects so that no single institution has to carry this work alone.","marks":[],"data":{}}]},{"nodeType":"heading-4","data":{},"content":[{"nodeType":"text","value":"Technical Coordinator Priorities & their Value to Hyrax and Hyku Institutions","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"1. Technical Triage & Support","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" - 6 hours/month","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Value to institutions:","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" Your teams get expert guidance without hiring additional staff. Questions are answered more quickly, reducing blockers during implementation and upgrades.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"2. Maintenance Coordination","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" - 5 hours/month","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Value to institutions:","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" Proactive coordination helps prevent crisis situations. Shared planning reduces duplicated effort and makes better use of limited developer time across institutions.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"3. Community Process & Communication","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" - 4 hours/month","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Value to institutions:","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" Developers spend less time navigating processes and more time doing productive work. New contributors and staff onboard faster and more confidently.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"4. Strategic Planning & Alignment","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" - 3 hours/month","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Value to institutions:","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" You gain clearer insight into where the community is headed and how to align your local roadmap with shared priorities.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"5. Documentation & Reporting","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" - 2 hours/month","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Value to institutions:","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":" Improved visibility into project health supports long-term planning and helps justify continued institutional investment.","marks":[],"data":{}}]},{"nodeType":"heading-4","data":{},"content":[{"nodeType":"text","value":"What This Role Cannot Do (Given Current Constraints)","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"This role is scoped at 20 hours per month, and it does not include:","marks":[],"data":{}}]},{"nodeType":"unordered-list","data":{},"content":[{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Extensive hands-on development work","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Comprehensive documentation or training creation","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Detailed accessibility testing","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Ongoing community website maintenance beyond critical fixes","marks":[],"data":{}}]}]},{"nodeType":"list-item","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Large-scale mentorship programs","marks":[],"data":{}}]}]}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"These are all areas where the community could grow as funding stabilizes. The current focus is on high-impact coordination work that multiplies the effectiveness of community contributions.","marks":[],"data":{}}]},{"nodeType":"heading-4","data":{},"content":[{"nodeType":"text","value":"Funding Shared Staffing for our Shared Responsibilities","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"This role exists because the Samvera Community recognizes that shared infrastructure requires shared staffing.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"To sustain this position beyond 2026 and to further expand it to incorporate priorities like training and documentation, everyone who relies on Hyrax and Hyku for critical infrastructure must ","marks":[],"data":{}},{"nodeType":"hyperlink","data":{"uri":"https://samvera.org/the-community/contribute"},"content":[{"nodeType":"text","value":"contribute to support","marks":[],"data":{}}]},{"nodeType":"text","value":" this shared work. No single institution can carry this work alone. Shared funding enables shared leadership, reduces burnout, and protects the long-term health of the software we all depend on.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Supporting Samvera is not just an investment in code but in people, coordination, and continuity. We’ll have more information available in the coming weeks about how to support Samvera through ","marks":[],"data":{}},{"nodeType":"hyperlink","data":{"uri":"https://samvera.org/the-community/contribute"},"content":[{"nodeType":"text","value":"financial contribution and Partnership.","marks":[],"data":{}}]},{"nodeType":"text","value":"","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"We are grateful to Rob for stepping into this role. Please join us in welcoming Rob as Samvera’s Technical Coordinator, and in committing together to the shared responsibility that makes this work possible.","marks":[],"data":{}}]}]}}}]},"__N_SSG":true}